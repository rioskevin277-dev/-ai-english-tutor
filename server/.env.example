# AI Provider API Keys (server-side only — never exposed to client)
GROQ_API_KEY=gsk_your_groq_api_key_here
OPENAI_API_KEY=sk_your_openai_api_key_here
ANTHROPIC_API_KEY=sk-ant_your_anthropic_api_key_here

# Server
PORT=3001

# CORS: comma-separated origins allowed (use * for development)
CORS_ORIGIN=*

# Rate limit: max requests per IP per window
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
